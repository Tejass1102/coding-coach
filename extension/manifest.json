{
  "manifest_version": 3,
  "name": "Coding Coach",
  "version": "1.0",
  "description": "AI-powered code analysis using Deep Learning — get instant feedback on your LeetCode solutions",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://leetcode.com/*", "http://127.0.0.1:8000/*"],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Coding Coach"
  }
}
